# Azure OpenAI (OPTIONAL — only needed if you add answer-synthesis generation step)
# Retrieval path is fully local; leave these unset unless generating answers.
AZURE_OPENAI_ENDPOINT=https://rdopenaidev.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=REDACTED_REPLACE_ME
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4_1_dev_1

# Local models (no API key needed; downloaded on first use / preflight)
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Paths
DATA_DIR=./data
INDEX_DIR=./indices
OUTPUT_DIR=./outputs

# Indexing defaults
CHUNK_SIZE=512
CHUNK_OVERLAP=51
CHUNK_STRATEGY=recursive

# Retrieval defaults
TOP_K_RETRIEVE=100
TOP_K_RERANK=20
TOP_K_FINAL=5
FUSION_METHOD=rrf
HYBRID_ALPHA=0.5
RRF_K=60
