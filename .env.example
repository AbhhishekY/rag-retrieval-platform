# Optional overrides. All defaults live in src/rag/constants.py.
# Uncomment and edit only what you want to override.

# Models (both served via FastEmbed / ONNX Runtime, no PyTorch)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Paths
# DATA_DIR=./data
# INDEX_DIR=./indices
# OUTPUT_DIR=./outputs

# Chunking
# CHUNK_SIZE=512
# CHUNK_OVERLAP=51
# CHUNK_STRATEGY=recursive

# Retrieval
# TOP_K_RETRIEVE=100
# TOP_K_RERANK=20
# TOP_K_FINAL=5
# FUSION_METHOD=rrf
# HYBRID_ALPHA=0.5
# RRF_K=60
# USE_RERANK_DEFAULT=true

# Batch sizes
# EMBED_BATCH_SIZE=64
# RERANK_BATCH_SIZE=32
